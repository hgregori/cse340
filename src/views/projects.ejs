<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <%= new Date(project.date).toLocaleDateString() %>:
                <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong>
                -
                <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
            </li>
        <% }); %>
    </ul>
    <p id="createBtn">Create project<a href='/new-project'>Add New Project</a></p>
</main>

<%- include('partials/footer') %>   